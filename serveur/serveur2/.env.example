# ========================================
# FICHIER DE CONFIGURATION - EXEMPLE
# ========================================
# 
# INSTRUCTIONS:
# 1. Renommez ce fichier en ".env" (sans .example)
# 2. Modifiez les valeurs ci-dessous selon votre configuration
# 3. Placez ce fichier dans le même dossier que SageExport.exe
#

# ========================================
# CONFIGURATION SQL SERVER
# ========================================
# Pour SQL Server, utilisez cette configuration:

DB_DRIVER=SQL Server  #sqlserver
DB_SERVER=localhost\SQLEXPRESS #DB_SERVER=NOM-DU-SERVEUR\SAGE100    127.0.0.1
# # Configuration base de données Sage (SQL Server)
# DB_DRIVER=sqlserver
# # Authentification SQL Server
# Mode 1: Authentification SQL (Standard)!!!!!!!!!!!!!
DB_USER=votre_utilisateur
DB_PASSWORD=votre_mot_de_passe
DB_TRUSTED_CONNECTION=false

# Mode 2: Authentification Windows (Trusted Connection)
# Pour ce mode, DB_USER et DB_PASSWORD seront ignorés
# DB_TRUSTED_CONNECTION=true!!!!!!!!!!!!!!!!!

# Exemples de DB_SERVER:
# - localhost\SQLEXPRESS (instance locale par défaut)
# - 192.168.1.100\SQLEXPRESS (serveur distant)
# - SERVEUR-NOM\INSTANCE (serveur nommé)

# ========================================
# MAPPING DES BASES DE DONNÉES
# ========================================
# Définit quelle base SQL utiliser pour chaque option du menu Client
DB_DATABASE_JACOB=SAGE_TEST #!!!!!!!!!
DB_DATABASE_ADIKIMYA=adkimya


# ========================================
# CONFIGURATION MYSQL (Alternative)
# ========================================
# Si vous utilisez MySQL au lieu de SQL Server, 
# commentez la section SQL Server ci-dessus et 
# décommentez les lignes ci-dessous:

# DB_DRIVER=MySQL ODBC 8.0 Driver
# DB_SERVER=localhost
# DB_USER=root
# DB_PASSWORD=votre_mot_de_passe


# ========================================
# NOTES IMPORTANTES
# ========================================
# 
# 1. Les noms de bases de données sont définis dans l'application:
#    - "jacob" utilise la base "SAGE_TEST"
#    - "adikimya" utilise la base "adkimya"
#
# 2. Assurez-vous que l'utilisateur a les droits de lecture 
#    sur les tables F_DOCENTETE et F_COMPTET
#
# 3. Pour SQL Server, vérifiez que:
#    - Le service SQL Server est démarré
#    - L'authentification SQL Server est activée
#    - Le port 1433 est ouvert (si serveur distant)
#
# 4. Pour MySQL, installez le connecteur ODBC:
#    https://dev.mysql.com/downloads/connector/odbc/
#
