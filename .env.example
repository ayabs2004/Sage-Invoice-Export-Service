# ============================================================
# FICHIER DE CONFIGURATION - MODÈLE (.env.example)
# ============================================================
#
# INSTRUCTIONS :
#   1. Copiez ce fichier et renommez-le en ".env"
#   2. Remplissez les valeurs selon votre environnement
#   3. Ne commitez JAMAIS le fichier ".env" sur Git !
#
# ============================================================

# ── Driver ODBC ─────────────────────────────────────────────
# SQL Server : "SQL Server" ou "ODBC Driver 17 for SQL Server"
# MySQL      : "MySQL ODBC 8.0 Driver"
DB_DRIVER=SQL Server

# ── Serveur de base de données ───────────────────────────────
# Exemples :
#   localhost\SQLEXPRESS    (instance locale)
#   192.168.1.100\SAGE100   (serveur distant)
#   SERVEUR-NOM\INSTANCE
DB_SERVER=localhost\SQLEXPRESS

# ── Authentification ─────────────────────────────────────────
# Mode 1 : Authentification SQL Standard
DB_USER=votre_utilisateur
DB_PASSWORD=votre_mot_de_passe
DB_TRUSTED_CONNECTION=false

# Mode 2 : Authentification Windows (Trusted Connection)
# Mettez DB_TRUSTED_CONNECTION=true  (DB_USER et DB_PASSWORD seront ignorés)

# ── Mapping des bases de données par société ─────────────────
# Format : DB_DATABASE_<NOM_SOCIETE_EN_MAJUSCULES>=<Nom_de_la_base>
# Exemple pour la société "JACOB" :
DB_DATABASE_JACOB=SAGE_TEST

# Exemple pour la société "ADIKIMYA" :
DB_DATABASE_ADIKIMYA=adkimya

# Optionnel : base séparée pour les lignes de documents
# DB_DATABASE_JACOB_LIGNE=SAGE_TEST_LIGNES
